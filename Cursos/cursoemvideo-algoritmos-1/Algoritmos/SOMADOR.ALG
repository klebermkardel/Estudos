Algoritmo "SOMADOR"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 26/03/2023
Var
// Seçăo de Declaraçőes das variáveis
  cont, N, S, maior, menor: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   S <- 0
   cont <- 1
   Enquanto (cont <= 5) faca
            Escreva("Digite o ", cont, "o. número: ")
            Leia(N)
            Se (cont = 1) entao
               maior <- N
               menor <- N
            Senao
                 Se (N > maior) entao
                    maior <- N
                 FimSe
                 Se (N < menor) entao
                    menor <- N
                 FimSe
            FimSe
            S <- S + N
            cont <- cont + 1
   FimEnquanto
   Escreval ("Soma:", S)
   Escreval ("Maior valor:", maior)
   Escreval ("Menor valor:", menor)
Fimalgoritmo