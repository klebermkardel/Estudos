Algoritmo "diadasmulheres"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 30/03/2023
Var
// Seçăo de Declaraçőes das variáveis 
   s: caractere
   preco, desc, vFinal: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   Escreva("Informe o valor do produto: ")
   Leia(preco)
   Escreva("Informe o seu sexo: ")
   Leia(s)
   Se(s = "H") entao
        desc <- 5
        vFinal <- preco - (preco * desc/100)
        Escreval()
        Escreval("Preço do produto: ", preco)
        Escreval("Valor com desconto: ", vFinal)
   senao Se (s = "M") entao
            desc <- 13
            vFinal <- preco - (preco * desc/100)
            Escreval()
            Escreval("Preço do produto: ", preco)
            Escreval("Valor com desconto: ", vFinal)
   FimSe

   

Fimalgoritmo